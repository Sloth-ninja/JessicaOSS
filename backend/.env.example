PORT=3001
FRONTEND_URL=http://localhost:3000

# HMAC key used to sign /download/:token URLs. Required at startup.
# Generate with: openssl rand -hex 32
# Use a dedicated secret distinct from SUPABASE_SECRET_KEY.
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=your-supabase-service-role-key

R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET_NAME=mike

GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENAI_API_KEY=your-openai-key
RESEND_API_KEY=your-resend-key
USER_API_KEYS_ENCRYPTION_SECRET=your-long-random-secret

# Companies House API key (free: developer.company-information.service.gov.uk)
COMPANIES_HOUSE_API_KEY=your-companies-house-key

# Firm administration (WS8). When set, new/orgless users are auto-assigned to
# this organisation (as members) on first profile load. Leave unset for
# self-hosters — orgless users keep the existing per-user behaviour. Create the
# organisation row and set this to its uuid via docs/FIRM_SETUP.md.
# DEFAULT_ORGANISATION_ID=00000000-0000-0000-0000-000000000000

# Rate limit for the UK research routes (/companies; /legislation later).
# Defaults: 120 requests per 15-minute window.
# RATE_LIMIT_RESEARCH_WINDOW_MINUTES=15
# RATE_LIMIT_RESEARCH_MAX=120

# Citation Checker rate limit (POST /citations/check — each request accepts up
# to 20,000 characters and can fan out into up to 50 sequential live
# legislation.gov.uk lookups). Defaults shown.
# RATE_LIMIT_CITATIONS_MAX=20
# RATE_LIMIT_CITATIONS_WINDOW_MINUTES=15

# Local / on-premises models (any OpenAI-compatible /v1/chat/completions server:
# Ollama, LM Studio, vLLM). Data-sovereignty mode — see docs/local-models.md.
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODELS=qwen2.5:14b-instruct
# LOCAL_LLM_API_KEY=
# OPENAI_BASE_URL is honoured as an alias for LOCAL_LLM_BASE_URL when the latter is unset.
